MONGODB_DATABASE=linkedin_agent
NICHE_KEYWORDS="AI, RAG, LLM, SaaS, automation, customer support"
REDDIT_SUBREDDITS="SaaS, artificial, customerservice, LangChain, LocalLLaMA"
GITHUB_TOPICS="rag,llm,ai-agents,langgraph,vector-database"
